{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "savingsCategoryIds": { "type": "array", "items": { "type": "string" } },
        "savingsPlan": { "type": "object" }
      },
      "required": ["uid", "email"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction (income or expense)",
      "type": "object",
      "properties": {
        "authorUid": { "type": "string" },
        "title": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "note": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorUid", "title", "amount", "category", "date", "type"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Monthly budget allocation for a category",
      "type": "object",
      "properties": {
        "authorUid": { "type": "string" },
        "month": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorUid", "month", "category", "amount"]
    },
    "Category": {
      "title": "Category",
      "description": "Custom user-defined category",
      "type": "object",
      "properties": {
        "authorUid": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "hex": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorUid", "name", "icon", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Main user document"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User transactions subcollection"
    },
    "/users/{userId}/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "User budgets subcollection"
    },
    "/users/{userId}/categories/{categoryId}": {
      "schema": "Category",
      "description": "User custom categories subcollection"
    }
  }
}

# GEMINI_API_KEY: used ONLY as a Cloudflare Worker secret (wrangler secret put
# GEMINI_API_KEY in whatsapp-bot/). The app build never reads it — all client
# AI calls go through the Worker's authenticated /ai proxy.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# AI proxy endpoint (the deployed whatsapp-bot Worker). Baked into the client;
# safe to expose — every request requires a Firebase ID token.
VITE_AI_PROXY_URL=https://flux-whatsapp-bot.example.workers.dev

# Firebase web app config — from Firebase Console > Project settings > Your apps.
# VITE_-prefixed vars are exposed to the client bundle via import.meta.env.
VITE_FIREBASE_API_KEY=MY_FIREBASE_API_KEY
VITE_FIREBASE_PROJECT_ID=my-project-id
VITE_FIREBASE_AUTH_DOMAIN=my-project-id.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=my-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
# Optional: only for a NAMED Firestore database; leave unset for (default).
# VITE_FIREBASE_DATABASE_ID=

# WhatsApp bot number (digits only, country code included) shown by the
# "Link WhatsApp" button in Settings. This is Meta's TEST number in dev mode.
VITE_WA_BOT_NUMBER=15551234567

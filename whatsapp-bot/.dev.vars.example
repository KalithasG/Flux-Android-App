GEMINI_API_KEY=AIza...your-gemini-key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"flux-v1-6a563","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-...@flux-v1-6a563.iam.gserviceaccount.com",...}
